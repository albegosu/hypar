// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [vector(map: "pgvector")]
}

// Document = original uploaded file or note
model Document {
  id           String   @id @default(uuid())
  title        String
  content      String   // Full original content
  sourceType   String   // 'text', 'markdown', 'pdf', 'web'
  workspaceId  String
  metadata     Json?    // Flexible metadata
  ingestStatus String   @default("pending") // 'pending' | 'processing' | 'ready' | 'failed'
  ingestError  String?
  chunkCount   Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  chunks       Chunk[]
  workspace    Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([ingestStatus])
}

// Chunk = split pieces of document for embedding
model Chunk {
  id           String   @id @default(uuid())
  documentId   String
  content      String   // The actual text chunk
  embedding    Unsupported("vector(768)")  // NOT NULL — chunks without vectors are bugs
  index        Int      // Position in document
  tokenCount   Int?     // Token count

  // For citations
  startChar    Int?
  endChar      Int?

  createdAt    DateTime @default(now())

  document     Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
}

// Conversation = a chat session, optionally per user
model Conversation {
  id          String    @id @default(uuid())
  workspaceId String
  title       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  messages    Message[]
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, updatedAt])
}

// Message = one turn in a conversation. Persists Vercel AI SDK UIMessage parts.
model Message {
  id             String       @id @default(uuid())
  conversationId String
  role           String       // 'user' | 'assistant' | 'system' | 'tool'
  content        String       // Plain-text rendering for quick listing
  parts          Json?        // Full UIMessage.parts (text + tool calls + tool results)
  sources        Json?        // [{chunkId, documentId, documentTitle, score}] when role='assistant'
  errorMessage   String?      // Set if the assistant turn failed mid-stream
  createdAt      DateTime     @default(now())

  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}

// Workspace = shared scope for documents and conversations
model Workspace {
  id            String            @id @default(cuid())
  name          String
  ownerId       String
  createdAt     DateTime          @default(now())

  owner         User              @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  members       WorkspaceMember[]
  documents     Document[]
  conversations Conversation[]

  @@index([ownerId])
}

// WorkspaceMember = user ↔ workspace membership
model WorkspaceMember {
  workspaceId String
  userId      String
  role        String   @default("editor") // owner | editor | viewer
  createdAt   DateTime @default(now())

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([workspaceId, userId])
  @@index([userId])
}

// Runtime-editable configuration. Overrides env vars when set.
// category is one of: embeddings | chunking | search | rag
model Setting {
  key       String   @id
  value     String
  category  String   @default("general")
  updatedAt DateTime @updatedAt

  @@index([category])
}

// Per-user settings overrides. Resolution order: UserSetting → Setting → env.
// Secret values (API keys) are AES-256-GCM encrypted at rest.
model UserSetting {
  userId    String
  key       String
  value     String
  category  String   @default("general")
  encrypted Boolean  @default(false)
  updatedAt DateTime @updatedAt

  @@id([userId, key])
  @@index([userId, category])
}

// ── better-auth tables ────────────────────────────────────────
// Tables are created by migration 20260512000000_add_auth (raw SQL).
// Models defined here so the Prisma client is aware of them.

model User {
  id            String    @id
  name          String
  email         String    @unique
  emailVerified Boolean   @default(false)
  image         String?
  role          String    @default("user")
  banned        Boolean?  @default(false)
  banReason     String?
  banExpires    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  sessions          Session[]
  accounts          Account[]
  ownedWorkspaces   Workspace[]
  workspaceMemberships WorkspaceMember[]
}

model Session {
  id             String   @id
  expiresAt      DateTime
  token          String   @unique
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  ipAddress      String?
  userAgent      String?
  userId         String
  impersonatedBy String?

  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime? @default(now())
  updatedAt  DateTime?
}

// Query history for analytics
model Query {
  id             String   @id @default(uuid())
  queryText      String
  responseText   String?
  sources        Json?    // Array of {chunkId, score, content}
  latencyMs      Int?     // Response time
  userId         String?
  conversationId String?
  toolCalled     Boolean  @default(false)
  createdAt      DateTime @default(now())

  @@index([createdAt])
  @@index([userId, createdAt])
}
