{
  "name": "from-zero-rag",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "hypar — unified Nuxt 3 app (RAG UI + multi-user auth)",
  "scripts": {
    "dev": "nuxt dev",
    "build": "nuxt build",
    "start": "node .output/server/index.mjs",
    "generate": "nuxt generate",
    "postinstall": "nuxt prepare && prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "lint": "eslint .",
    "eval": "node --import tsx scripts/eval.ts",
    "typecheck": "vue-tsc --noEmit",
    "reingest": "tsx scripts/reingest-all.ts",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "demo:poster": "npx -p playwright@1.49.0 node scripts/capture-demo-poster.mjs"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.74",
    "@ai-sdk/google": "^3.0.67",
    "@ai-sdk/mistral": "^3.0.33",
    "@ai-sdk/openai": "^3.0.58",
    "@ai-sdk/vue": "^3.0.174",
    "@google/generative-ai": "^0.24.1",
    "@nuxt/icon": "^1.15.0",
    "@nuxt/ui": "^3.0.0",
    "@pinia/nuxt": "^0.5.1",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@vueuse/nuxt": "^11.0.0",
    "ai": "^6.0.174",
    "better-auth": "^1.6.10",
    "js-tiktoken": "^1.0.14",
    "marked": "^14.1.3",
    "pdf-parse": "^1.1.1",
    "pg": "^8.20.0",
    "pinia": "^2.1.7",
    "uuid": "^9.0.1",
    "vue": "^3.5.13",
    "vue-i18n": "^10.0.8",
    "vue-router": "^4.4.5",
    "workflow": "^4.2.4",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@nuxt/devtools": "latest",
    "@vitest/coverage-v8": "^2.1.0",
    "eslint": "^9.22.0",
    "globals": "^16.0.0",
    "redis": "^4.7.0",
    "typescript-eslint": "^8.26.0",
    "@tailwindcss/vite": "^4.2.4",
    "@types/node": "^20.10.0",
    "@types/pdf-parse": "^1.1.4",
    "@types/uuid": "^9.0.7",
    "dotenv": "^17.4.2",
    "gsap": "^3.15.0",
    "nuxt": "^3.15.3",
    "prisma": "^7.8.0",
    "tailwindcss": "^4.2.4",
    "tsx": "^4.19.0",
    "typescript": "^5.3.3",
    "vitepress": "^1.6.3",
    "vitest": "^2.1.0",
    "vue-tsc": "^3.2.7"
  },
  "keywords": [
    "rag",
    "learning",
    "gamification",
    "tutorial",
    "embeddings",
    "vector-database",
    "llm"
  ],
  "author": "Alberto González",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=10.0.0"
  }
}
