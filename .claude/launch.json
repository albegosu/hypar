{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "rag-ui",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["--filter", "rag-ui", "dev"],
      "port": 3000,
      "autoPort": true
    },
    {
      "name": "rag-api",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["--filter", "rag-api", "start:dev"],
      "port": 3001
    },
    {
      "name": "rag-playground",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["--filter", "@rag/playground", "exec", "nuxt", "dev"],
      "port": 3002,
      "autoPort": true
    }
  ]
}
